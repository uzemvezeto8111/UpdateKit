<Window x:Class="UpdateKit.Wpf.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Width="680"
        Height="620"
        MinWidth="560"
        MinHeight="500"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        SizeToContent="Manual"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Window.Style>
        <Style TargetType="Window">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsOperationInProgress}" Value="True">
                    <Setter Property="Cursor" Value="Wait" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,6"
                   FontSize="17"
                   FontWeight="SemiBold"
                   Text="{Binding Heading}"
                   automation:AutomationProperties.Name="Update status heading" />
        <TextBlock Grid.Row="1"
                   Margin="0,0,0,14"
                   Text="{Binding ReleaseName}"
                   TextTrimming="CharacterEllipsis"
                   automation:AutomationProperties.Name="Release name" />

        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,2,14,5" Text="Available version:" />
            <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,2,0,5" Text="{Binding AvailableVersion}"
                       automation:AutomationProperties.Name="Available version" />
            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,2,14,5" Text="Published:" />
            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,2,0,5" Text="{Binding PublishedText}"
                       automation:AutomationProperties.Name="Publication date" />
            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,2,14,5" Text="Asset:" />
            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,2,0,5" Text="{Binding SelectedAssetText}"
                       TextTrimming="CharacterEllipsis"
                       automation:AutomationProperties.Name="Selected release asset" />
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Padding="0,0,0,5" Target="{Binding ElementName=ReleaseNotesBox}">Release notes:</Label>
            <TextBox x:Name="ReleaseNotesBox"
                     Grid.Row="1"
                     Padding="7"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     Text="{Binding ReleaseNotes, Mode=OneWay}"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     automation:AutomationProperties.Name="Release notes" />
        </Grid>

        <TextBlock Grid.Row="4"
                   Margin="0,0,0,7"
                   Text="{Binding StatusText}"
                   TextWrapping="Wrap"
                   automation:AutomationProperties.Name="Operation status" />

        <Grid Grid.Row="5" Margin="0,0,0,9">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ProgressBar Grid.Row="0"
                         Height="18"
                         Minimum="0"
                         Maximum="100"
                         IsIndeterminate="{Binding IsProgressIndeterminate}"
                         Value="{Binding ProgressPercentage}"
                         automation:AutomationProperties.Name="Download progress" />
            <TextBlock Grid.Row="1"
                       Margin="0,5,0,0"
                       HorizontalAlignment="Right"
                       Text="{Binding ProgressText}"
                       automation:AutomationProperties.Name="Downloaded bytes" />
        </Grid>

        <Border Grid.Row="6"
                Margin="0,0,0,12"
                Padding="9"
                Background="#FFFFE7E7"
                BorderBrush="#FFD13438"
                BorderThickness="1"
                Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Foreground="#FF8A1C1C"
                       Text="{Binding ErrorText}"
                       TextWrapping="Wrap"
                       automation:AutomationProperties.Name="Update error" />
        </Border>

        <StackPanel Grid.Row="7" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button MinWidth="118"
                    Margin="0,0,8,0"
                    Padding="12,5"
                    Command="{Binding PrimaryActionCommand}"
                    Content="{Binding PrimaryActionText}"
                    IsDefault="True"
                    automation:AutomationProperties.Name="Primary update action" />
            <Button MinWidth="88"
                    Margin="0,0,8,0"
                    Padding="12,5"
                    Command="{Binding CancelCommand}"
                    Content="Cancel"
                    IsCancel="False"
                    automation:AutomationProperties.Name="Cancel update operation" />
            <Button MinWidth="88"
                    Padding="12,5"
                    Click="CloseButton_Click"
                    Content="Close"
                    IsCancel="True"
                    IsEnabled="{Binding CanClose}"
                    automation:AutomationProperties.Name="Close update window" />
        </StackPanel>
    </Grid>
</Window>
